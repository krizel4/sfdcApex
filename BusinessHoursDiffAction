public class BusinessHoursDiffAction {
    
    public class Request {
        @InvocableVariable(required=true label='Start DateTime')
        public DateTime startDateTime;
        
        @InvocableVariable(required=true label='End DateTime')
        public DateTime endDateTime;
        
        @InvocableVariable(label='Business Hours Name')
        public String businessHoursName;
    }
    
    public class Result {
        @InvocableVariable(label='Difference in Hours')
        public Decimal diffInHours;
    }
    
    @InvocableMethod(label='Calculate Business Hours Difference' 
                     description='Returns the difference in hours between two DateTimes, excluding non-business hours and weekends')
    public static List<Result> calculateDiff(List<Request> requests) {
        List<Result> results = new List<Result>();
        
        BusinessHours defaultBH = [
            SELECT Id FROM BusinessHours WHERE IsDefault = true LIMIT 1
        ];
        
        for (Request req : requests) {
            Result res = new Result();
            
            BusinessHours bh = defaultBH;
            if (req.businessHoursName != null) {
                List<BusinessHours> namedBH = [
                    SELECT Id FROM BusinessHours 
                    WHERE Name = :req.businessHoursName LIMIT 1
                ];
                if (!namedBH.isEmpty()) {
                    bh = namedBH[0];
                }
            }
            
            Long diffInMillis = BusinessHours.diff(
                bh.Id, req.startDateTime, req.endDateTime
            );
            
            res.diffInHours = Decimal.valueOf(diffInMillis) / (1000.0 * 60 * 60);
            res.diffInHours = res.diffInHours.setScale(2);
            
            results.add(res);
        }
        
        return results;
    }
}
